{
  "name": "htmltopdfpro-demo",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Professional high-fidelity HTML to PDF solution, implemented as a pure TypeScript frontend component.",
  "homepage": "https://htmltopdfpro.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wybaby168/HtmlToPdfPro.git"
  },
  "keywords": [
    "html-to-pdf",
    "pdf",
    "typescript",
    "vite",
    "html2canvas",
    "jspdf",
    "pagedjs"
  ],
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "dev": "pnpm --filter @flyfish-dev/html2pdf-js build && vite --host 0.0.0.0",
    "build": "pnpm --filter @flyfish-dev/html2pdf-js build && tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "pnpm --filter @flyfish-dev/html2pdf-js build && tsc --noEmit",
    "pack:package": "pnpm --dir packages/html2pdf-js pack",
    "publish:package": "cd packages/html2pdf-js && npm publish --access public --registry=https://registry.npmjs.org/"
  },
  "dependencies": {
    "@flyfish-dev/html2pdf-js": "workspace:*"
  },
  "devDependencies": {
    "javascript-obfuscator": "^5.4.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.11"
  }
}
