{
  "name": "htmltopdfpro-demo",
  "version": "4.0.2",
  "private": true,
  "type": "module",
  "description": "Self-contained TypeScript HTML to PDF engine with high-fidelity visual rendering and selectable text layer.",
  "homepage": "https://htmltopdfpro.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wybaby168/html2pdf-js.git"
  },
  "keywords": [
    "html-to-pdf",
    "pdf",
    "typescript",
    "copyable-text",
    "text-layer",
    "frontend",
    "browser",
    "dom-renderer",
    "canvas"
  ],
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "dev": "npm --prefix packages/html2pdf-js run build && vite --host 0.0.0.0",
    "build": "npm --prefix packages/html2pdf-js run build && tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "npm --prefix packages/html2pdf-js run build && tsc --noEmit",
    "pack:package": "cd packages/html2pdf-js && npm pack",
    "publish:package": "cd packages/html2pdf-js && npm publish --access public --registry=https://registry.npmjs.org/",
    "test:pdf": "tsc -p packages/html2pdf-js/tsconfig.json && node tests/browser-pdf-smoke.mjs && node tests/full-demo-pdf-smoke.mjs"
  },
  "dependencies": {
    "@flyfish-dev/html2pdf-js": "workspace:*"
  },
  "devDependencies": {
    "javascript-obfuscator": "^5.4.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.11"
  }
}
