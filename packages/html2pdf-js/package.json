{
  "name": "@flyfish-dev/html2pdf-js",
  "version": "4.0.3",
  "description": "Self-contained TypeScript HTML to PDF engine with high-fidelity visual rendering and selectable text layer.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "keywords": [
    "html-to-pdf",
    "pdf",
    "typescript",
    "copyable-text",
    "text-layer",
    "frontend",
    "browser",
    "dom-renderer",
    "canvas"
  ],
  "homepage": "https://htmltopdfpro.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wybaby168/html2pdf-js.git",
    "directory": "packages/html2pdf-js"
  },
  "bugs": {
    "url": "https://github.com/wybaby168/html2pdf-js/issues"
  },
  "license": "AGPL-3.0-only",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
